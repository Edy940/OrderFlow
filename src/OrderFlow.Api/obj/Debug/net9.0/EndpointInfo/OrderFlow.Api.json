{
  "openapi": "3.0.1",
  "info": {
    "title": "OrderFlow.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/Clientes": {
      "get": {
        "tags": [
          "Clientes"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Pedidos": {
      "post": {
        "tags": [
          "Pedidos"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CriarPedidoDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CriarPedidoDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CriarPedidoDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/api/Produtos": {
      "get": {
        "tags": [
          "Produtos"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CriarPedidoDto": {
        "type": "object",
        "properties": {
          "clienteId": {
            "type": "string",
            "format": "uuid"
          },
          "itens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemPedidoDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ItemPedidoDto": {
        "type": "object",
        "properties": {
          "produtoId": {
            "type": "string",
            "format": "uuid"
          },
          "quantidadeId": {
            "type": "integer",
            "format": "int32"
          },
          "quantidade": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  }
}